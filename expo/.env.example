# RevenueCat API Key (for in-app purchases)
# Get this from https://app.revenuecat.com/
# Leave empty to use test key in development (not recommended for production)
EXPO_PUBLIC_REVENUECAT_API_KEY=

# SurrealDB Configuration (if using backend database)
# These must be provided by the project owner
EXPO_PUBLIC_RORK_DB_ENDPOINT=
EXPO_PUBLIC_RORK_DB_NAMESPACE=
EXPO_PUBLIC_RORK_DB_TOKEN=
